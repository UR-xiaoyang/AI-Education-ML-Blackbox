# AI Edu Backend - Environment Variables
# Copy this file to .env and fill in the values

# ===================
# REQUIRED IN PRODUCTION
# ===================

# JWT Secret - MUST be set in production (min 32 characters recommended)
# Generate with: openssl rand -base64 32
JWT_SECRET=

# ===================
# OPTIONAL
# ===================

# Server port
PORT=3001

# JWT expiration
JWT_EXPIRES_IN=7d

# Default admin account created only when no admin user exists
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=Admin@123456
DEFAULT_ADMIN_DISPLAY_NAME=系统管理员

# Initial system settings inserted on first database creation
ALLOW_REGISTRATION=false
TURNSTILE_ENABLED=false

# Database mode (sqlite or postgres)
DB_MODE=sqlite

# Cloudflare Turnstile keys (optional - leave empty to disable)
# Required when TURNSTILE_ENABLED is enabled from system settings
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
